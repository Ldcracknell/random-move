#!/usr/bin/env bash

hide_dest=false
file=""
for arg in "$@"; do
  case "$arg" in
    -h|--hide-dest) hide_dest=true ;;
    -*)
      echo "unknown option: $arg" >&2
      echo "usage: random-move <file> [-e|--hide-dest]" >&2
      exit 1
      ;;
    *)
      if [[ -n "$file" ]]; then
        echo "usage: random-move <file> [-e|--hide-dest]" >&2
        exit 1
      fi
      file=$arg
      ;;
  esac
done

if [[ -z "$file" ]]; then
  echo "usage: random-move <file> [-e|--hide-dest]" >&2
  exit 1
fi

if [[ ! -f "$file" ]]; then
  echo "$file is not a file" >&2
  exit 1
fi

src=$(realpath -- "$file")

walked=false
while true; do
  dirs=()
  for name in *; do
    [[ -d "$name" ]] && dirs+=("$name")
  done

  n=${#dirs[@]}

  if ((n == 0)); then
    if [[ "$walked" != true ]]; then
      echo "no subdirectories here (need at least one folder step)" >&2
      exit 1
    fi
    break
  fi

  if [[ "$walked" == true ]]; then
    idx=$((RANDOM % (n + 1)))
    if ((idx == n)); then
      break
    fi
  else
    idx=$((RANDOM % n))
  fi

  cd -- "${dirs[idx]}" || exit 1
  walked=true
done

mv -- "$src" . || exit 1

if [[ "$hide_dest" == true ]]; then
  echo "success: moved to ???"
else
  dest=$(realpath -- "$(basename -- "$src")")
  echo "success: moved to $dest"
fi
