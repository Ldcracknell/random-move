#!/usr/bin/env bash

hide_dest=false
rename=false
file=""
for arg in "$@"; do
  case "$arg" in
    -h|--hide-dest) hide_dest=true ;;
    -r|--rename) rename=true ;;
    -*)
      echo "unknown option: $arg" >&2
      echo "usage: random-move <file> [-h|--hide-dest] [-r|--rename]" >&2
      exit 1
      ;;
    *)
      if [[ -n "$file" ]]; then
        echo "usage: random-move <file> [-h|--hide-dest] [-r|--rename]" >&2
        exit 1
      fi
      file=$arg
      ;;
  esac
done

if [[ -z "$file" ]]; then
  echo "usage: random-move <file> [-h|--hide-dest] [-r|--rename]" >&2
  exit 1
fi

if [[ ! -f "$file" ]]; then
  echo "$file is not a file" >&2
  exit 1
fi

src=$(realpath -- "$file")

walked=false
while true; do
  dirs=()
  for name in *; do
    [[ -d "$name" ]] && dirs+=("$name")
  done

  n=${#dirs[@]}

  if ((n == 0)); then
    if [[ "$walked" != true ]]; then
      echo "no subdirectories here (need at least one folder step)" >&2
      exit 1
    fi
    break
  fi

  if [[ "$walked" == true ]]; then
    idx=$((RANDOM % (n + 1)))
    if ((idx == n)); then
      break
    fi
  else
    idx=$((RANDOM % n))
  fi

  cd -- "${dirs[idx]}" || exit 1
  walked=true
done

dest_name=$(basename -- "$src")
if [[ "$rename" == true ]]; then
  base=$dest_name
  if [[ "$base" == *.* ]]; then
    ext=".${base##*.}"
  else
    ext=""
  fi
  while true; do
    if command -v openssl >/dev/null 2>&1; then
      id=$(openssl rand -hex 8)
    else
      id=$(printf '%08x%08x' "$RANDOM" "$RANDOM")
    fi
    dest_name="${id}${ext}"
    [[ ! -e "$dest_name" ]] && break
  done
fi

mv -- "$src" "./$dest_name" || exit 1

if [[ "$rename" == true ]]; then
  if [[ "$hide_dest" == true ]]; then
    echo "success: moved to ??? and renamed"
  else
    loc=$(realpath -- "$dest_name")
    echo "success: moved to $(dirname -- "$loc") and renamed"
  fi
else
  if [[ "$hide_dest" == true ]]; then
    echo "success: moved to ???"
  else
    loc=$(realpath -- "$dest_name")
    echo "success: moved to $loc"
  fi
fi
