#!/usr/bin/env bash

if [[ -z "$1" ]]; then
  echo "usage: random-save <file>" >&2
  exit 1
fi

if [[ ! -f "$1" ]]; then
  echo "$1 is not a file" >&2
  exit 1
fi

src=$(realpath -- "$1")

while true; do
  dirs=()
  for name in *; do
    [[ -d "$name" ]] && dirs+=("$name")
  done

  n=${#dirs[@]}
  idx=$((RANDOM % (n + 1)))
  if ((idx == n)); then
    break
  fi
  cd -- "${dirs[idx]}" || exit 1
done

cp -- "$src" . || exit 1

dest=$(realpath -- "$(basename -- "$src")")
echo "success: copied to $dest"
